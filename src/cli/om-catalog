#!/usr/bin/env bash
# om catalog — Browse, search, and discover repos in the Omarchy catalog
set -euo pipefail

OM_ROOT="${OM_ROOT:-$(cd "$(dirname "$(dirname "$(dirname "$0")")")" && pwd)}"
ALL_JSON="$OM_ROOT/catalog/all.json"
cli_dir="$(dirname "$0")"
# shellcheck source=src/cli/om-ui
. "$cli_dir/om-ui"

usage() {
    ui_brand "Omarchy Catalog" "Curated repositories, themes, configs, and ecosystem tooling."
    ui_section "Usage"
    ui_command "om catalog list [category]" "List repos by category"
    ui_command "om catalog search <query>" "Search repos by name"
    ui_command "om catalog show <repo>" "Inspect one repository"
    ui_command "om catalog recommend [count]" "Surface mature/high-signal repos"
    ui_command "om catalog browse" "Open the fzf catalog browser"
    ui_command "om catalog stats" "Show catalog statistics"
    ui_section "Categories"
    ui_note "themes/gui-apps   themes/waybar   themes/colorschemes   themes/gtk"
    ui_note "tools             configs         curated                related"
    ui_section "Examples"
    ui_command "om catalog list themes/colorschemes" "All color schemes"
    ui_command "om catalog search retro" "Search for retro repos"
    ui_command "om catalog show omarchist" "Details on omarchist"
    ui_command "om catalog recommend" "Top 10 popular repos"
}

list_category() {
    local cat="$1" sub="$2"
    local dir="$OM_ROOT/repos/$cat"
    [[ -n "$sub" ]] && dir="$dir/$sub"
    if [[ ! -d "$dir" ]]; then
        ui_warning "Category not found: $cat${sub:+/}$sub"
        ui_note "Try: om catalog list themes/gui-apps"
        exit 1
    fi
    ui_header "Catalog / $cat${sub:+/}$sub" "$dir"
    count=0
    shopt -s nullglob
    for repo in "$dir"/*/; do
        [[ -d "$repo/.git" ]] || continue
        name=$(basename "$repo")
        printf '  %b%-42s%b %s\n' "$CYAN" "$name" "$NC" "$(ui_badge repo)"
        count=$((count + 1))
    done
    shopt -u nullglob
    ui_kv "Total" "$count"
}

list_all() {
    ui_brand "Repo Catalog" "Scannable inventory of installed Omarchy ecosystem repos."
    shopt -s nullglob
    for cat in themes tools configs curated related; do
        case $cat in
            themes)
                ui_section "Themes"
                for sub in gui-apps waybar colorschemes gtk; do
                    c=0
                    for r in "$OM_ROOT/repos/$cat/$sub"/*/; do
                        [[ -d "$r/.git" ]] && c=$((c+1))
                    done
                    printf '  %b%-26s%b %4d repos\n' "$GREEN" "$cat/$sub" "$NC" "$c"
                done
                ;;
            *)
                c=0
                for r in "$OM_ROOT/repos/$cat"/*/; do
                    [[ -d "$r/.git" ]] && c=$((c+1))
                done
                ui_section "${cat^}"
                printf '  %b%-26s%b %4d repos\n' "$GREEN" "$cat" "$NC" "$c"
                ;;
        esac
    done
    shopt -u nullglob
}

search_repos() {
    local query="$1"
    ui_header "Catalog Search" "Query: $query"

    # Walk all repos and match name
    found=0
    grep_query=$(echo "$query" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9-]//g')
    while IFS= read -r -d '' dir; do
        name=$(basename "$(dirname "$dir")")
        name_lower=$(echo "$name" | tr '[:upper:]' '[:lower:]')
        if echo "$name_lower" | grep -q "$grep_query"; then
            rel="$(dirname "${dir#"$OM_ROOT"/}")"
            printf '  %b%-42s%b %s\n' "$CYAN" "$name" "$NC" "${DIM}$rel${NC}"
            found=$((found + 1))
        fi
    done < <(find -L "$OM_ROOT/repos" -name '.git' -type d -print0 2>/dev/null)

    if (( found == 0 )); then
        ui_warn "No repos match '$query'"
    else
        ui_kv "Found" "$found"
    fi
}

show_repo() {
    local name="$1"
    # Find repo path by exact name (must contain .git to be a repo root)
    path=$(find -L "$OM_ROOT/repos" -maxdepth 4 -type d -name "$name" -exec test -d "{}/.git" \; -print 2>/dev/null | head -1)
    if [[ -z "$path" ]]; then
        ui_error "Repo not found: $name"
        ui_note "Run 'om catalog list' to see all repos."
        exit 1
    fi
    rel="${path#"$OM_ROOT"/}"
    ui_brand "$name" "Catalog repository profile"
    ui_kv "Path" "$rel"
    ui_kv "Size" "$(du -sh "$path" 2>/dev/null | cut -f1)"
    ui_kv "Contents" "$(find "$path" -type f | wc -l) files"
    # Show subdirectories
    ui_section "Structure"
    shopt -s nullglob
    for item in "$path"/*/; do echo "    $(basename "$item")/"; done
    shopt -u nullglob
    [[ -f "$path/README.md" ]] && ui_kv "README" "$(head -1 "$path/README.md" 2>/dev/null | head -c 80)"
}

recommend() {
    local limit="${1:-10}"
    ui_brand "Recommended Repos" "Based on maturity, stars, uniqueness, and local availability. Limit: $limit"

    size_of() {
        local d="$1"
        du -sh "$d" 2>/dev/null | cut -f1 || echo "?"
    }

    ui_section "Top Configurations"
    for dir in ArchRiot okimarchy omarchy-config omarchy-titus; do
        p=$(find -L "$OM_ROOT/repos" -maxdepth 4 -type d -name "$dir" -exec test -d "{}/.git" \; -print 2>/dev/null | head -1)
        [[ -n "$p" ]] && printf '  %b%-40s%b %s\n' "$CYAN" "$dir" "$NC" "${DIM}$(size_of "$p")${NC}"
    done

    ui_section "Top Themes"
    for dir in aetheria omarchy-retropc-theme omarchy-one-dark-pro-theme \
               omarchy-coppernight-theme omarchy-lumon-theme omarchy-sapphire-theme \
               omarchy-evergarden omarchy-rose-pine omarchy-synthwave84-theme; do
        p=$(find -L "$OM_ROOT/repos" -maxdepth 4 -type d -name "$dir" -exec test -d "{}/.git" \; -print 2>/dev/null | head -1)
        [[ -n "$p" ]] && printf '  %b%-40s%b %s\n' "$CYAN" "$dir" "$NC" "${DIM}$(size_of "$p")${NC}"
    done

    ui_section "Top Tools"
    for dir in wayscriber hyprmon ostt hyprwhspr awesome-omarchy-tui \
               omarchy-cleaner omarchy-background-changer; do
        p=$(find -L "$OM_ROOT/repos" -maxdepth 4 -type d -name "$dir" -exec test -d "{}/.git" \; -print 2>/dev/null | head -1)
        [[ -n "$p" ]] && printf '  %b%-40s%b %s\n' "$CYAN" "$dir" "$NC" "${DIM}$(size_of "$p")${NC}"
    done
}

catalog_stats() {
    local total=0
    ui_brand "Catalog Statistics" "Repository counts by release category."
    printf "  %-25s %s\n" "Category" "Count"
    printf "  %-25s %s\n" "----------------------" "-----"
    shopt -s nullglob
    for cat in themes tools configs curated related; do
        c=0
        case $cat in
            themes)
                for sub in gui-apps waybar colorschemes gtk; do
                    for r in "$OM_ROOT/repos/$cat/$sub"/*/; do
                        [[ -d "$r/.git" ]] && c=$((c+1))
                    done
                done
                ;;
            *)
                for r in "$OM_ROOT/repos/$cat"/*/; do
                    [[ -d "$r/.git" ]] && c=$((c+1))
                done
                ;;
        esac
        printf "  %-25s %d\n" "$cat" "$c"
        total=$((total + c))
    done
    printf "  %-25s %s\n" "----------------------" "-----"
    printf "  %-25s %d\n" "TOTAL" "$total"
    shopt -u nullglob
    printf '\n'
    ui_kv "Generated" "$(date -r "$ALL_JSON" 2>/dev/null || echo 'N/A')"
}

browse_catalog() {
    if ! command -v fzf &>/dev/null; then
        ui_error "fzf not found. Install it: pacman -S fzf"
        exit 1
    fi
    local choice
    choice=$(find -L "$OM_ROOT/repos" -name '.git' -type d -exec dirname {} \; 2>/dev/null \
        | while IFS= read -r dir; do
            name=$(basename "$dir")
            rel="${dir#"$OM_ROOT"/}"
            printf "%-40s %s\n" "$name" "$rel"
        done | sort | fzf --prompt="om catalog> " --header="Select a repo to view details" \
            --preview="bash -c 'om catalog show {1}' 2>/dev/null || true" \
            --preview-window=right:60%:wrap \
            --height=80% --layout=reverse --border)
    if [[ -n "$choice" ]]; then
        local name
        name=$(echo "$choice" | awk '{print $1}')
        show_repo "$name"
    fi
}

# --- Dispatch ---
CMD="${1:-help}"; shift 2>/dev/null || true

case "$CMD" in
    list|l)
        SUB="${1:-}"
        if [[ -z "$SUB" ]]; then
            list_all
        else
            cat_part="${SUB%%/*}"
            sub_part="${SUB#*/}"
            [[ "$cat_part" == "$sub_part" ]] && sub_part=""
            list_category "$cat_part" "$sub_part"
        fi
        ;;
    search|s)
        [[ -z "${1:-}" ]] && { ui_error "Usage: om catalog search <query>"; exit 1; }
        search_repos "$1"
        ;;
    show|view)
        [[ -z "${1:-}" ]] && { ui_error "Usage: om catalog show <repo-name>"; exit 1; }
        show_repo "$1"
        ;;
    recommend|rec)
        recommend "${1:-10}"
        ;;
    browse|b)
        browse_catalog
        ;;
    stats)
        catalog_stats
        ;;
    help|-h|--help) usage ;;
    *) ui_error "Unknown catalog subcommand: $CMD"; usage; exit 1 ;;
esac
