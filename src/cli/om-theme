#!/usr/bin/env bash
# om theme — Theme management for Omarchy
set -euo pipefail

OM_ROOT="${OM_ROOT:-$(cd "$(dirname "$(dirname "$(dirname "$0")")")" && pwd)}"
THEME_DIR="${OMARCHY_THEME_DIR:-$HOME/.config/omarchy/themes}"
CURRENT_LINK="${OMARCHY_CURRENT:-$HOME/.config/omarchy/current/theme}"
HOOK_DIR="${OMARCHY_HOOK_DIR:-$HOME/.config/omarchy/hooks}"
cli_dir="$(dirname "$0")"
# shellcheck source=src/cli/om-ui
. "$cli_dir/om-ui"

usage() {
    ui_brand "Omarchy Theme Studio" "Install, inspect, and apply complete visual systems."
    ui_section "Usage"
    ui_command "om theme list" "List available themes"
    ui_command "om theme set <name>" "Apply a theme"
    ui_command "om theme current" "Show the active theme"
    ui_command "om theme install <url>" "Install a theme from git"
    ui_command "om theme remove <name>" "Remove a user-installed theme"
    ui_command "om theme preview <name>" "Show theme preview metadata"
    ui_section "Examples"
    ui_command "om theme list" "See all themes"
    ui_command "om theme set tokyo-night" "Apply Tokyo Night"
    ui_command "om theme current" "Inspect active theme"
}

list_themes() {
    ui_brand "Available Themes" "$THEME_DIR"
    if [[ ! -d "$THEME_DIR" ]]; then
        ui_warn "No themes directory found at $THEME_DIR"
        ui_note "Install themes: om theme install <git-url>"
        return
    fi
    count=0
    for t in "$THEME_DIR"/*/; do
        [[ -d "$t" ]] || continue
        name=$(basename "$t")
        current=""
        if [[ -L "$CURRENT_LINK" ]] && [[ "$(readlink "$CURRENT_LINK")" == "$(cd "$t" && pwd)" ]]; then
            current=" $(ui_badge active)"
        fi
        printf '  %b%-42s%b %s\n' "$CYAN" "$name" "$NC" "$current"
        count=$((count + 1))
    done
    ui_kv "Total" "$count"
}

current_theme() {
    if [[ -L "$CURRENT_LINK" ]]; then
        target=$(readlink "$CURRENT_LINK")
        name=$(basename "$target")
        ui_brand "$name" "Active theme"
        ui_kv "Path" "$target"
        if [[ -f "$target/colors.toml" ]]; then
            ui_kv "Colors" "$(grep -c '=' "$target/colors.toml" 2>/dev/null || echo 0) vars"
        fi
        if [[ -d "$target/backgrounds" ]]; then
            ui_kv "Backgrounds" "$(find "$target/backgrounds" -type f | wc -l) files"
        fi
        # Show which config files this theme provides
        ui_section "Provided Files"
        for f in waybar.css walker.css hyprland.conf hyprlock.conf mako.ini alacritty.toml neovim.lua; do
            [[ -f "$target/$f" ]] && ui_ok "$f"
        done
    else
        ui_warning "No theme set"
        ui_note "Set one: om theme set <name>"
    fi
}

set_theme() {
    local name="$1"
    local theme_path=""

    # 1. Check user-installed themes first
    if [[ -d "$THEME_DIR/$name" ]]; then
        theme_path="$THEME_DIR/$name"
    # 2. Search catalog repos for a matching theme
    else
        theme_path=$(find -L "$OM_ROOT/repos" -maxdepth 4 -type d -name "$name" -exec test -d "{}/.git" \; -print 2>/dev/null | head -1)
        if [[ -z "$theme_path" ]]; then
            ui_error "Theme not found: $name"
            ui_note "Search themes: om theme list"
            ui_note "Search catalog: om catalog search $name"
            exit 1
        fi
        ui_note "Found in catalog: $theme_path"
    fi

    # Ensure current link parent exists
    mkdir -p "$(dirname "$CURRENT_LINK")"
    ln -sfT "$theme_path" "$CURRENT_LINK"
    ui_brand "Theme Applied" "$name"

    # Copy theme configs to ~/.config/omarchy/current/
    local config_dir
    config_dir=$(dirname "$CURRENT_LINK")
    mkdir -p "$config_dir"
    for f in waybar.css walker.css hyprland.conf hyprlock.conf mako.ini alacritty.toml kitty.conf ghostty.conf neovim.lua colors.toml; do
        if [[ -f "$theme_path/$f" ]]; then
            cp "$theme_path/$f" "$config_dir/$f"
            ui_ok "$f"
        fi
    done

    # Apply wallpaper
    local bg_dir="$theme_path/backgrounds"
    if [[ -d "$bg_dir" ]]; then
        local bg
        bg=$(find -L "$bg_dir" -type f \( -name '*.png' -o -name '*.jpg' -o -name '*.webp' -o -name '*.jpeg' \) | shuf -n 1)
        [[ -n "$bg" ]] && {
            hyprctl hyprpaper preload "$bg" 2>/dev/null || true
            hyprctl hyprpaper wallpaper ",$bg" 2>/dev/null || true
            ui_ok "Wallpaper applied"
        }
    fi

    # Apply colors.toml to Hyprland config (generate env vars)
    if [[ -f "$theme_path/colors.toml" ]]; then
        ui_ok "Colors loaded from colors.toml"
    fi

    # Reload services
    hyprctl reload 2>/dev/null || true
    pkill -USR2 waybar 2>/dev/null || true
    ui_ok "Hyprland reloaded, Waybar refreshed"

    # Run hooks
    local hook_path="$HOOK_DIR/theme-set"
    if [[ -x "$hook_path" ]]; then
        "$hook_path" "$name"
        ui_ok "Hook executed"
    fi
    # Also run module hooks
    if [[ -d "$OM_ROOT/modules/theme-hook/hooks" ]]; then
        for hook in "$OM_ROOT/modules/theme-hook/hooks"/*.sh; do
            [[ -x "$hook" ]] && { "$hook" "$theme_path" 2>/dev/null || true; }
        done
    fi
}

install_theme() {
    local url="${1:-}"
    [[ -z "$url" ]] && { ui_error "Usage: om theme install <git-url>"; exit 1; }
    name=$(basename "$url" .git)
    mkdir -p "$THEME_DIR"
    if [[ -d "$THEME_DIR/$name" ]]; then
        ui_warning "Theme already installed: $name"
        exit 1
    fi
    ui_header "Installing Theme" "$name"
    git clone "$url" "$THEME_DIR/$name"
    ui_success "Installed: $name"
    ui_note "Apply with: om theme set $name"
}

remove_theme() {
    local name="${1:-}"
    [[ -z "$name" ]] && { ui_error "Usage: om theme remove <name>"; exit 1; }
    if [[ ! -d "$THEME_DIR/$name" ]]; then
        ui_error "Theme not found: $name"
        exit 1
    fi
    # Can't remove active theme
    if [[ -L "$CURRENT_LINK" ]] && [[ "$(readlink "$CURRENT_LINK")" == "$(cd "$THEME_DIR/$name" && pwd)" ]]; then
        ui_warning "Cannot remove active theme. Switch first."
        exit 1
    fi
    rm -rf "${THEME_DIR:?}/$name"
    ui_success "Removed: $name"
}

preview_theme() {
    local name="${1:-}"
    [[ -z "$name" ]] && { ui_error "Usage: om theme preview <name>"; exit 1; }
    dir="$THEME_DIR/$name"
    [[ ! -d "$dir" ]] && { ui_error "Theme not found: $name"; exit 1; }

    ui_brand "Theme: $name" "Preview profile"
    ui_kv "Path" "$dir"
    [[ -f "$dir/preview.png" ]] && ui_kv "Preview" "$dir/preview.png"

    # Color info
    if [[ -f "$dir/colors.toml" ]]; then
        ui_section "Colors"
        head -12 "$dir/colors.toml" | while IFS= read -r line; do
            ui_note "$line"
        done
        total=$(wc -l < "$dir/colors.toml")
        (( total > 12 )) && ui_note "... ($(( total - 12 )) more)"
    fi

    # Config files
    ui_section "Config Files"
    for f in waybar.css walker.css hyprland.conf hyprlock.conf mako.ini alacritty.toml kitty.conf ghostty.conf neovim.lua vscode.json btop.theme swayosd.css chromium.theme icons.theme; do
        [[ -f "$dir/$f" ]] && ui_ok "$f"
    done
}

# --- Dispatch ---
CMD="${1:-help}"; shift 2>/dev/null || true

case "$CMD" in
    list|ls)     list_themes ;;
    set|apply)   [[ -z "${1:-}" ]] && { echo "Usage: om theme set <name>"; exit 1; }
                 set_theme "$1" ;;
    current|cur) current_theme ;;
    install|i)   install_theme "${1:-}" ;;
    remove|rm)   remove_theme "${1:-}" ;;
    preview|pr)  preview_theme "${1:-}" ;;
    help|-h|--help) usage ;;
    *) ui_error "Unknown theme subcommand: $CMD"; usage; exit 1 ;;
esac
