#!/usr/bin/env bash
# om — Omarchy CLI Toolbox
# Inspired by Chris Titus Tech's linutil — modular system management CLI
set -euo pipefail

OM_ROOT="${OM_ROOT:-$(cd "$(dirname "$(dirname "$(dirname "$0")")")" && pwd)}"
OM_VERSION="1.0.0"
cli_dir="$(dirname "$0")"
# shellcheck source=src/cli/om-ui
. "$cli_dir/om-ui"

usage() {
    ui_brand "Omarchy Command Center  v$OM_VERSION" "Release-grade tooling for themes, diagnostics, catalogs, labs, recovery, and TUI control."
    ui_section "Usage"
    ui_command "om <command> [options]" "Run a workspace command"
    ui_section "Command Matrix"
    ui_command "catalog" "Browse/search repos: list, search, show, recommend, browse, stats"
    ui_command "theme" "Manage themes: list, set, current, install, remove, preview"
    ui_command "system" "Inspect and repair: info, health, diagnose, stabilize, reload, guard"
    ui_command "lab" "Mine cloned repos for tools, ideas, and release tracks"
    ui_command "tui" "Open the interactive dashboard"
    ui_command "status" "Project overview and quick health"
    ui_command "update" "Pull latest from all cloned repos"
    ui_command "extract" "Extract assets from repos into dist/"
    ui_command "version" "Show CLI version"
    ui_command "install" "Install om into /usr/local/bin"
    ui_section "Examples"
    ui_command "om catalog list" "List all repos"
    ui_command "om catalog search retro" "Search retro-themed repos"
    ui_command "om theme set tokyo-night" "Apply a theme"
    ui_command "om lab runway" "Show the next feature tracks"
    ui_command "om tui" "Open the interactive dashboard"
    ui_command "om system health" "Run health checks"
    ui_command "om status" "Show the release dashboard"
    printf '\n%b\n' "${DIM}Run 'om <command> --help' for subcommand details.${NC}"
}

cmd_catalog() { bash "$cli_dir/om-catalog" "$@"; }
cmd_theme()   { bash "$cli_dir/om-theme" "$@"; }
cmd_system()  { bash "$cli_dir/om-system" "$@"; }
cmd_lab()     { bash "$cli_dir/om-lab" "$@"; }
cmd_tui()     { bash "$cli_dir/om-tui" "$@"; }

# --- Direct commands ---
cmd_status() {
    bash "$OM_ROOT/src/scripts/extract.sh" --status 2>/dev/null || true
    local repo_count custom_dirs
    repo_count=$(find -L "$OM_ROOT/repos" -name '.git' -type d 2>/dev/null | wc -l)
    custom_dirs=$(find "$OM_ROOT" -mindepth 1 -maxdepth 1 -type d ! -name repos 2>/dev/null | wc -l)

    ui_brand "Omarchy Project Overview" "Operational dashboard for the local release workspace."
    ui_section "Build Identity"
    ui_kv "Root" "$OM_ROOT"
    ui_kv "Version" "$OM_VERSION"
    ui_kv "Repos" "$repo_count"
    ui_kv "Custom Dirs" "$custom_dirs"

    ui_section "Quick Health"
    for d in catalog modules templates tests nexus singularity hologram; do
      if [[ -d "$OM_ROOT/$d" ]]; then
          ui_ok "$d/"
      else
          ui_err "$d/"
      fi
    done
}

cmd_update() {
    ui_header "Repository Update" "Fast-forward pull across cloned Omarchy repos."
    find -L "$OM_ROOT/repos" -name '.git' -type d -execdir sh -c 'echo "  $(basename "$(dirname "$(pwd)")")/$(basename "$(pwd)")" && git pull --ff-only 2>/dev/null || true' \;
    ui_success "Done."
}

cmd_extract() {
    bash "$OM_ROOT/src/scripts/extract.sh"
}

cmd_version() {
    ui_brand "om v$OM_VERSION" "Omarchy project at: $OM_ROOT"
}

cmd_install() {
    local target="/usr/local/bin/om"
    local src="$OM_ROOT/src/cli/om"

    if [[ -L "$target" ]] || [[ -e "$target" ]]; then
        local existing
        existing=$(readlink -f "$target" 2>/dev/null || echo "unknown")
        if [[ "$existing" == "$src" ]]; then
            ui_success "Already installed: $target -> $src"
            return 0
        fi
        ui_warning "Warning: $target already exists (points to $existing)"
        ui_note "Remove it first: sudo rm $target"
        return 1
    fi

    ui_header "Install" "Linking om into /usr/local/bin."
    sudo ln -sf "$src" "$target"
    ui_success "Installed: $target -> $src"
    ui_note "You can now run 'om' from anywhere."
}

# --- Main dispatch ---
CMD="${1:-help}"; shift 2>/dev/null || true

case "$CMD" in
    catalog|cat)  cmd_catalog "$@" ;;
    theme|th)     cmd_theme "$@" ;;
    system|sys)   cmd_system "$@" ;;
    lab|labs)     cmd_lab "$@" ;;
    tui|dashboard) cmd_tui "$@" ;;
    status|st)    cmd_status ;;
    update|up)    cmd_update ;;
    extract|ext)  cmd_extract ;;
    install|i)    cmd_install ;;
    version|ver)  cmd_version ;;
    help|-h|--help) usage ;;
    *) ui_error "Unknown command: $CMD"; usage; exit 1 ;;
esac
