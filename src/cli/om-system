#!/usr/bin/env bash
# om system — System management, health checks, and diagnostics
# Inspired by linutil — system info, troubleshooting, stabilization
set -euo pipefail

OM_ROOT="${OM_ROOT:-$(cd "$(dirname "$(dirname "$(dirname "$0")")")" && pwd)}"
cli_dir="$(dirname "$0")"
# shellcheck source=src/cli/om-ui
. "$cli_dir/om-ui"

usage() {
    ui_brand "Omarchy Systems Console" "Diagnostics, health checks, and session repair."
    ui_section "Usage"
    ui_command "om system info" "System information overview"
    ui_command "om system health" "Health check and diagnostics"
    ui_command "om system diagnose" "Collect focused runtime diagnostics"
    ui_command "om system stabilize [--inhibit]" "Stabilize Wayland session"
    ui_command "om system reload" "Reload Hyprland config"
    ui_command "om system guard" "Ensure Waybar is running once"
    ui_section "Examples"
    ui_command "om system info" "Show system info"
    ui_command "om system health" "Run health checks"
    ui_command "om system diagnose" "Print logs and service diagnostics"
    ui_command "om system stabilize" "Kill runaway processes and restart guards"
    ui_command "om system reload" "Debounced Hyprland reload"
}

have() { command -v "$1" &>/dev/null; }

proc_count() {
    local count
    count=$(pgrep -cx "$1" 2>/dev/null) || count=0
    printf '%s\n' "$count"
}

hypr_socket2() {
    local sig="${HYPRLAND_INSTANCE_SIGNATURE:-}"
    [[ -z "$sig" ]] && return 1

    local dir
    for dir in "${XDG_RUNTIME_DIR:-}/hypr/$sig" "/tmp/hypr/$sig"; do
        [[ -n "$dir" && -S "$dir/.socket2.sock" ]] && {
            printf '%s\n' "$dir/.socket2.sock"
            return 0
        }
    done
    return 1
}

system_info() {
    ui_brand "System Information" "Host profile and desktop session context."

    # OS
    if [[ -f /etc/os-release ]]; then
        # shellcheck disable=SC1091
        . /etc/os-release
        ui_kv "OS" "$PRETTY_NAME"
    fi
    ui_kv "Kernel" "$(uname -r)"
    ui_kv "Uptime" "$(uptime -p 2>/dev/null || uptime | awk -F, '{print $1}')"
    ui_kv "Shell" "$SHELL"
    ui_kv "Terminal" "${TERM:-unknown}"

    # Desktop
    if [[ -n "${HYPRLAND_INSTANCE_SIGNATURE:-}" ]]; then
        ui_kv "WM" "Hyprland (${HYPRLAND_INSTANCE_SIGNATURE:0:8})"
        monitor_count=$(hyprctl monitors -j 2>/dev/null | python3 -c "import sys,json; print(len(json.load(sys.stdin)))" 2>/dev/null || echo "?")
        ui_kv "Monitors" "$monitor_count"
    else
        ui_kv "WM" "Not Hyprland (or no session)"
    fi

    # Hardware
    ui_section "Hardware"
    ui_kv "CPU" "$(lscpu 2>/dev/null | grep 'Model name' | head -1 | cut -d: -f2 | xargs || echo '?')"
    mem_total=$(grep MemTotal /proc/meminfo | awk '{printf "%.1f GB", $2/1024/1024}')
    ui_kv "Memory" "$mem_total"
    ui_kv "GPU" "$(lspci 2>/dev/null | grep -i 'vga\|3d' | head -1 | cut -d: -f3 | xargs || echo '?')"

    # Audio
    if have pactl; then
        if ! sink_count=$(pactl list sinks short 2>/dev/null | wc -l); then
            sink_count=0
        fi
        ui_kv "Audio sinks" "$sink_count"
    fi
}

health_check() {
    local errors=0 warnings=0

    ui_brand "Health Check" "Desktop runtime, services, catalog, and disk status."

    # 1. Hyprland
    if [[ -n "${HYPRLAND_INSTANCE_SIGNATURE:-}" ]]; then
        ui_ok "Hyprland session detected"
        if hypr_socket2 >/dev/null; then
            ui_ok "Hyprland socket2 available"
        else
            ui_warn "Hyprland socket2 not found"
            warnings=$((warnings + 1))
        fi
    else
        ui_warn "No Hyprland session"
        warnings=$((warnings + 1))
    fi

    # 2. Waybar
    if pgrep -x waybar > /dev/null; then
        count=$(proc_count waybar)
        if (( count == 1 )); then
            ui_ok "Waybar running (1 instance)"
        else
            ui_warn "Waybar: $count instances"
            warnings=$((warnings + 1))
        fi
    else
        ui_err "Waybar not running"
        errors=$((errors + 1))
    fi

    # 3. PipeWire
    if have pactl && pactl info &>/dev/null; then
        ui_ok "PipeWire audio running"
    else
        ui_err "PipeWire not available"
        errors=$((errors + 1))
    fi

    # 4. Notification daemon
    if pgrep -x mako > /dev/null || pgrep -x dunst > /dev/null || pgrep -x swaync > /dev/null; then
        ui_ok "Notification daemon running"
    else
        ui_warn "No notification daemon"
        warnings=$((warnings + 1))
    fi

    # 5. Display manager
    if [[ -n "${WAYLAND_DISPLAY:-}" ]]; then
        ui_ok "Wayland display: $WAYLAND_DISPLAY"
    fi

    # 6. Battery
    if [[ -d /sys/class/power_supply/BAT0 ]]; then
        cap=$(cat /sys/class/power_supply/BAT0/capacity 2>/dev/null || echo "?")
        ui_ok "Battery: ${cap}%"
    fi

    # 7. Repos
    repo_count=$(find -L "$OM_ROOT/repos" -name '.git' -type d 2>/dev/null | wc -l)
    ui_ok "$repo_count cloned repos"

    # 8. Disk space
    avail=$(df -h "$OM_ROOT" | tail -1 | awk '{print $4}')
    ui_ok "Disk available: $avail"

    # Summary
    echo
    if (( errors > 0 )); then
        ui_err "$errors errors, $warnings warnings"
    elif (( warnings > 0 )); then
        ui_warn "All pass, $warnings warnings"
    else
        ui_success "  All checks pass"
    fi
}

stabilize() {
    ui_brand "Stabilizing Session" "Waybar, hypridle, and optional sleep inhibition."

    local repaired=0

    # Waybar
    wc=$(proc_count waybar)
    if (( wc > 1 )); then
        have waybar || { ui_err "waybar command not found"; return 1; }
        ui_warn "Killing $(( wc - 1 )) duplicate Waybar instances"
        pkill -x waybar; sleep 0.5
        waybar &>/dev/null &
        ui_ok "Waybar restarted"
        repaired=1
    elif (( wc == 0 )); then
        have waybar || { ui_err "waybar command not found"; return 1; }
        ui_warn "Starting Waybar"
        waybar &>/dev/null &
        ui_ok "Waybar started"
        repaired=1
    else
        ui_ok "Waybar OK (1 instance)"
    fi

    # Hypridle
    if have hypridle; then
        killall hypridle 2>/dev/null || true
        sleep 0.3
        hypridle &>/dev/null &
        ui_ok "Hypridle restarted"
        repaired=1
    else
        ui_warn "hypridle command not found"
    fi

    # Inhibit
    if [[ "${1:-}" == "--inhibit" ]]; then
        have systemd-inhibit || { ui_err "systemd-inhibit command not found"; return 1; }
        systemd-inhibit --what=sleep --why="Omarchy stabilize" sleep infinity &
        ui_ok "Sleep inhibitor started"
        repaired=1
    fi

    if (( repaired )); then
        ui_success "Session stabilized"
    else
        ui_success "Session already stable"
    fi
}

reload() {
    have hyprctl || { ui_error "hyprctl not found"; return 1; }
    ui_header "Reload" "Reloading Hyprland and refreshing Waybar."
    hyprctl reload
    ui_ok "Hyprland reloaded"
    pkill -USR2 waybar 2>/dev/null || true
    ui_ok "Waybar refreshed"
}

guard() {
    if pgrep -x waybar > /dev/null; then
        count=$(proc_count waybar)
        if (( count > 1 )); then
            ui_warn "Killing $((count - 1)) duplicate Waybar instances"
            for pid in $(pgrep -x waybar | tail -n +2); do kill "$pid" 2>/dev/null || true; done
        fi
        ui_ok "Waybar running (single instance)"
    else
        have waybar || { ui_error "waybar not found"; return 1; }
        ui_warn "Waybar not running - starting"
        waybar &>/dev/null &
        ui_ok "Waybar started"
    fi
}

diagnose() {
    ui_brand "Omarchy Diagnostics" "Focused runtime evidence for release support."
    system_info
    echo
    health_check

    ui_section "Hyprland"
    if have hyprctl; then
        local hypr_errors socket
        if hypr_errors=$(hyprctl configerrors 2>&1); then
            if [[ -n "$hypr_errors" ]]; then
                while IFS= read -r line; do printf '  %s\n' "$line"; done <<< "$hypr_errors"
            else
                echo "  no config errors"
            fi
        else
            echo "  hyprctl unavailable for this session"
            [[ -n "$hypr_errors" ]] && while IFS= read -r line; do printf '  %s\n' "$line"; done <<< "$hypr_errors"
        fi
        if socket=$(hypr_socket2); then
            ui_kv "socket2" "$socket"
        else
            ui_kv "socket2" "unavailable"
        fi
    else
        ui_kv "hyprctl" "not installed"
    fi

    ui_section "Failed Units"
    if have systemctl; then
        systemctl --user --failed --no-pager 2>/dev/null || echo "  user units: unavailable"
        systemctl --failed --no-pager 2>/dev/null || echo "  system units: unavailable"
    else
        ui_kv "systemctl" "not installed"
    fi

    ui_section "Recent Warnings"
    if have journalctl; then
        journalctl -b -p warning..alert --no-pager -n 40 2>/dev/null || echo "  journal unavailable"
    else
        ui_kv "journalctl" "not installed"
    fi
}

# --- Dispatch ---
CMD="${1:-help}"; shift 2>/dev/null || true

case "$CMD" in
    info)       system_info ;;
    health)      health_check ;;
    diagnose|diag) diagnose ;;
    stabilize)  stabilize "${1:-}" ;;
    reload)     reload ;;
    guard)      guard ;;
    help|-h|--help) usage ;;
    *) ui_error "Unknown system subcommand: $CMD"; usage; exit 1 ;;
esac
